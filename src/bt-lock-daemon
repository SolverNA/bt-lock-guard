#!/usr/bin/env python3
"""
bt-lock-daemon — Bluetooth Presence Lock for KDE Plasma (X11 / Kali Linux)

Monitors a Bluetooth device by MAC address.
If RSSI drops below threshold for N consecutive checks, locks the KDE screen.
Writes real-time state to ~/.local/share/bt-lock-guard/state.json
Reads config from ~/.config/bt-lock-guard/config.json

https://github.com/SolVerNA/bt-lock-guard
License: MIT
"""

import argparse
import json
import logging
import os
import signal
import subprocess
import sys
import time
import fcntl

try:
    import dbus
    HAS_DBUS = True
except ImportError:
    HAS_DBUS = False

# ── Paths ──────────────────────────────────────────────────────────────────────
STATE_DIR   = os.path.expanduser("~/.local/share/bt-lock-guard")
CONFIG_DIR  = os.path.expanduser("~/.config/bt-lock-guard")
LOG_FILE    = os.path.join(STATE_DIR, "daemon.log")
STATE_FILE  = os.path.join(STATE_DIR, "state.json")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
LOCK_FILE   = "/tmp/bt-lock-daemon.lock"

os.makedirs(STATE_DIR, exist_ok=True)
os.makedirs(CONFIG_DIR, exist_ok=True)

# ── Logging ────────────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.FileHandler(LOG_FILE),
        logging.StreamHandler(sys.stdout),
    ],
)
log = logging.getLogger("bt-lock-daemon")

# ── Default config ─────────────────────────────────────────────────────────────
DEFAULT_CONFIG = {
    "mac":       "",
    "threshold": -80,
    "misses":    3,
    "interval":  1,
    "grace":     30,
    "enabled":   True,
}


def load_config() -> dict:
    """Load config from file, falling back to defaults."""
    cfg = DEFAULT_CONFIG.copy()
    try:
        if os.path.exists(CONFIG_FILE):
            with open(CONFIG_FILE) as f:
                cfg.update(json.load(f))
    except Exception as e:
        log.warning("Could not read config: %s", e)
    return cfg


def write_state(mac: str, rssi: int | None, present: bool,
                miss_count: int, locked: bool, enabled: bool,
                threshold: int, status: str) -> None:
    """Write current state to JSON for tray to read."""
    state = {
        "mac":        mac,
        "rssi":       rssi,
        "present":    present,
        "miss_count": miss_count,
        "locked":     locked,
        "enabled":    enabled,
        "threshold":  threshold,
        "status":     status,
        "ts":         time.time(),
    }
    try:
        tmp = STATE_FILE + ".tmp"
        with open(tmp, "w") as f:
            json.dump(state, f)
        os.replace(tmp, STATE_FILE)
    except Exception as e:
        log.debug("State write error: %s", e)


# ── BlueZ D-Bus helpers ────────────────────────────────────────────────────────
def _bluez_devices() -> dict:
    """Return {path: props} for all org.bluez.Device1 objects."""
    if not HAS_DBUS:
        return {}
    try:
        bus = dbus.SystemBus()
        mgr = dbus.Interface(bus.get_object("org.bluez", "/"),
                             "org.freedesktop.DBus.ObjectManager")
        return {
            path: ifaces["org.bluez.Device1"]
            for path, ifaces in mgr.GetManagedObjects().items()
            if "org.bluez.Device1" in ifaces
        }
    except Exception as e:
        log.debug("D-Bus device list error: %s", e)
        return {}


def _find_device_path(mac: str) -> tuple[str | None, dict | None]:
    """Return (dbus_path, props) for a device by MAC, or (None, None)."""
    for path, props in _bluez_devices().items():
        if str(props.get("Address", "")).upper() == mac.upper():
            return path, props
    return None, None


# ── BlueZ helpers ──────────────────────────────────────────────────────────────
def bt_is_powered() -> bool:
    """Return True if the Bluetooth adapter is currently powered on."""
    if HAS_DBUS:
        try:
            bus = dbus.SystemBus()
            mgr = dbus.Interface(bus.get_object("org.bluez", "/"),
                                 "org.freedesktop.DBus.ObjectManager")
            for path, ifaces in mgr.GetManagedObjects().items():
                if "org.bluez.Adapter1" in ifaces:
                    return bool(ifaces["org.bluez.Adapter1"].get("Powered", False))
        except Exception:
            pass
    try:
        r = subprocess.run(["bluetoothctl", "show"],
                           capture_output=True, text=True, timeout=5)
        return "Powered: yes" in r.stdout
    except Exception:
        return False


def bt_power_on() -> bool:
    """Power on the Bluetooth adapter. Return True on success."""
    try:
        r = subprocess.run(["bluetoothctl", "power", "on"],
                           capture_output=True, text=True, timeout=10)
        return r.returncode == 0
    except Exception as e:
        log.error("Failed to power on Bluetooth: %s", e)
        return False


def is_device_paired(mac: str) -> bool:
    """Return True if the device is already paired."""
    _, props = _find_device_path(mac)
    if props is not None:
        return bool(props.get("Paired", False))
    try:
        r = subprocess.run(["bluetoothctl", "info", mac],
                           capture_output=True, text=True, timeout=5)
        return "Paired: yes" in r.stdout
    except Exception:
        return False


def pair_device(mac: str) -> bool:
    """Discover, pair, trust and connect the device. Blocks up to ~45 s."""
    log.info("[SETUP] Scanning for %s …", mac)
    scan_proc = subprocess.Popen(
        ["bluetoothctl", "scan", "on"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    )
    try:
        time.sleep(8)
        log.info("[SETUP] Pairing with %s …", mac)
        r = subprocess.run(
            ["bluetoothctl", "--timeout", "30", "pair", mac],
            capture_output=True, text=True, timeout=35
        )
        out = r.stdout + r.stderr
        if "Pairing successful" in out or "Already Paired" in out:
            log.info("[SETUP] Pairing successful.")
            subprocess.run(["bluetoothctl", "trust", mac],
                           capture_output=True, timeout=5)
            subprocess.run(["bluetoothctl", "connect", mac],
                           capture_output=True, timeout=10)
            return True
        log.warning("[SETUP] Pairing failed: %s", out.strip())
        return False
    except subprocess.TimeoutExpired:
        log.warning("[SETUP] Pairing timed out.")
        return False
    except Exception as e:
        log.error("[SETUP] Pairing error: %s", e)
        return False
    finally:
        scan_proc.terminate()


def setup_phase(mac: str, threshold: int) -> None:
    """Block until BT is powered on and the device is paired."""
    while not bt_is_powered():
        log.info("[SETUP] Bluetooth is off — powering on…")
        write_state(mac, None, False, 0, False, True, threshold, "bt_off")
        if bt_power_on():
            log.info("[SETUP] Bluetooth powered on.")
        else:
            log.warning("[SETUP] Could not power on Bluetooth. Retrying in 5 s…")
            time.sleep(5)

    if not is_device_paired(mac):
        log.info("[SETUP] Device %s not paired — starting pairing…", mac)
        while not is_device_paired(mac):
            write_state(mac, None, False, 0, False, True, threshold, "pairing")
            if pair_device(mac):
                break
            log.info("[SETUP] Pairing unsuccessful. Retrying in 10 s…")
            time.sleep(10)
        log.info("[SETUP] Device %s paired successfully.", mac)
    else:
        log.info("[SETUP] Device %s already paired.", mac)


def get_rssi(mac: str) -> int | None:
    """
    Get RSSI in dBm.
    1. BlueZ D-Bus RSSI property (works for BLE; sometimes BR/EDR).
    2. bt-rssi helper binary (setcap cap_net_raw+ep, compiled at install).
    """
    # Try D-Bus first (fast, no subprocess)
    _, props = _find_device_path(mac)
    if props is not None:
        rssi = props.get("RSSI")
        if rssi is not None:
            return int(rssi)

    # Try the bt-rssi binary for BR/EDR
    try:
        r = subprocess.run(
            ["/usr/local/bin/bt-rssi", mac],
            capture_output=True, text=True, timeout=2
        )
        if r.returncode == 0 and r.stdout.strip():
            return int(r.stdout.strip())
    except FileNotFoundError:
        pass  # bt-rssi not compiled — install with `make install` from source
    except (ValueError, subprocess.TimeoutExpired, OSError):
        pass
    return None


def ping_device(mac: str) -> bool:
    """
    Presence check: D-Bus Connected property first (no root needed),
    l2ping as fallback (needs CAP_NET_RAW — set via AmbientCapabilities
    in the service file).
    """
    # Primary: D-Bus Connected property
    _, props = _find_device_path(mac)
    if props is not None and bool(props.get("Connected", False)):
        return True

    # Fallback: l2ping
    try:
        result = subprocess.run(
            ["l2ping", "-c", "1", "-t", "1", mac],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            timeout=1.5,
        )
        return result.returncode == 0
    except subprocess.TimeoutExpired:
        return False
    except FileNotFoundError:
        log.debug("l2ping not found — using D-Bus only")
        return False
    except PermissionError:
        log.debug("l2ping: permission denied — add AmbientCapabilities=CAP_NET_RAW to service")
        return False
    except Exception:
        return False


def force_connect(mac: str) -> None:
    """Connect device via D-Bus, fall back to bluetoothctl."""
    path, _ = _find_device_path(mac)
    if path and HAS_DBUS:
        try:
            bus = dbus.SystemBus()
            device = dbus.Interface(bus.get_object("org.bluez", path),
                                    "org.bluez.Device1")
            device.Connect()
            log.debug("D-Bus connect sent to %s", mac)
            return
        except Exception as e:
            log.debug("D-Bus connect error: %s", e)
    try:
        subprocess.Popen(
            ["bluetoothctl", "connect", mac],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
    except Exception as e:
        log.debug("bluetoothctl connect error: %s", e)


def trust_device(mac: str) -> None:
    try:
        subprocess.run(["bluetoothctl", "--timeout", "5", "trust", mac],
                       capture_output=True, timeout=7)
        log.info("Device %s trusted.", mac)
    except Exception as e:
        log.warning("Trust failed: %s", e)


def probe_device(mac: str, attempt_connect: bool) -> tuple[bool, int | None]:
    """
    Returns (present: bool, rssi: int | None).
    Uses BlueZ D-Bus for both presence and RSSI (no root required).
    l2ping is used as a fallback presence check.
    """
    rssi    = get_rssi(mac)
    present = ping_device(mac)   # checks Connected via D-Bus first

    if not present and attempt_connect:
        force_connect(mac)
        time.sleep(0.3)
        present = ping_device(mac)
        if present:
            rssi = get_rssi(mac)

    return present, rssi


# ── Session helpers ────────────────────────────────────────────────────────────
def is_screen_locked() -> bool:
    try:
        sessions = subprocess.check_output(
            ["loginctl", "list-sessions", "--no-legend"],
            text=True, timeout=3
        ).strip()
        for line in sessions.splitlines():
            parts = line.split()
            if not parts:
                continue
            sid = parts[0]
            try:
                info = subprocess.check_output(
                    ["loginctl", "show-session", sid,
                     "--property=LockedHint", "--property=Type"],
                    text=True, timeout=3
                )
                if any(t in info for t in ("Type=x11", "Type=wayland", "Type=mir")):
                    return "LockedHint=yes" in info
            except Exception:
                continue
    except Exception as e:
        log.debug("Session check error: %s", e)
    return False


def lock_screen() -> bool:
    env = os.environ.copy()
    uid = os.getuid()
    bus = f"/run/user/{uid}/bus"
    if "DBUS_SESSION_BUS_ADDRESS" not in env and os.path.exists(bus):
        env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={bus}"

    for cmd in (
        ["qdbus", "org.freedesktop.ScreenSaver", "/ScreenSaver", "Lock"],
        ["loginctl", "lock-session"],
    ):
        try:
            r = subprocess.run(cmd, env=env, capture_output=True, timeout=5)
            if r.returncode == 0:
                log.info("Screen locked via %s", cmd[0])
                return True
        except Exception:
            continue
    log.error("All lock methods failed.")
    return False


# ── Daemon ─────────────────────────────────────────────────────────────────────
def daemonize() -> None:
    if os.fork() > 0:
        sys.exit(0)
    os.setsid()
    if os.fork() > 0:
        sys.exit(0)
    with open(os.devnull, "r") as dn:
        os.dup2(dn.fileno(), sys.stdin.fileno())
    lf = open(LOG_FILE, "a")
    os.dup2(lf.fileno(), sys.stdout.fileno())
    os.dup2(lf.fileno(), sys.stderr.fileno())


def handle_signal(signum, _frame):
    log.info("Signal %d — exiting.", signum)
    sys.exit(0)


def monitor(mac: str, run_as_daemon: bool) -> None:
    # PID lock
    lf = open(LOCK_FILE, "w")
    try:
        fcntl.lockf(lf, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except IOError:
        print("Already running. Exiting.")
        sys.exit(1)

    if run_as_daemon:
        daemonize()

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    cfg              = load_config()
    setup_phase(mac, cfg.get("threshold", DEFAULT_CONFIG["threshold"]))
    miss_count       = 0
    was_locked       = is_screen_locked()
    allow_connect    = True
    cfg_reload_timer = 0

    log.info("=" * 50)
    log.info("bt-lock-daemon STARTED")
    log.info("MAC       : %s", mac)
    log.info("Threshold : %d dBm", cfg["threshold"])
    log.info("Misses    : %d", cfg["misses"])
    log.info("=" * 50)

    while True:
        # Reload config every 5 seconds (tray may have changed it)
        now = time.time()
        if now - cfg_reload_timer > 5:
            cfg = load_config()
            cfg_reload_timer = now

        enabled   = cfg.get("enabled", True)
        threshold = cfg.get("threshold", -80)
        max_miss  = cfg.get("misses", 3)
        interval  = cfg.get("interval", 1)
        grace     = cfg.get("grace", 30)

        # ── Disabled ──────────────────────────────────────────────────────────
        if not enabled:
            write_state(mac, None, False, 0, is_screen_locked(),
                        False, threshold, "disabled")
            time.sleep(2)
            continue

        currently_locked = is_screen_locked()

        # ── Screen locked ─────────────────────────────────────────────────────
        if currently_locked:
            if not was_locked:
                log.info("[LOCKED] Monitoring paused.")
            was_locked  = True
            miss_count  = 0
            allow_connect = True
            write_state(mac, None, False, 0, True, True, threshold, "locked")
            time.sleep(2)
            continue

        # ── Just unlocked — grace period ──────────────────────────────────────
        if was_locked and not currently_locked:
            log.info("[UNLOCKED] Grace period %d sec...", grace)
            force_connect(mac)
            write_state(mac, None, True, 0, False, True, threshold, "grace")
            time.sleep(grace)
            was_locked  = False
            miss_count  = 0
            allow_connect = True
            continue

        # ── Active monitoring ─────────────────────────────────────────────────
        present, rssi = probe_device(mac, allow_connect)

        # Threshold check: if RSSI is known and below threshold → treat as miss
        if rssi is not None and rssi < threshold:
            present = False
            log.debug("[RSSI] %d dBm < threshold %d dBm", rssi, threshold)

        if present:
            if miss_count > 0:
                log.info("[OK] Signal restored after %d miss(es). RSSI=%s",
                         miss_count, rssi)
            miss_count    = 0
            allow_connect = False
            write_state(mac, rssi, True, 0, False, True, threshold, "ok")
        else:
            miss_count   += 1
            allow_connect = True
            log.warning("[MISS] No signal (%d/%d). RSSI=%s", miss_count, max_miss, rssi)
            write_state(mac, rssi if rssi else -100, False,
                        miss_count, False, True, threshold, "miss")

            if miss_count >= max_miss:
                log.warning("[LOCK] Limit %d reached. LOCKING!", max_miss)
                if lock_screen():
                    was_locked = True
                    miss_count = 0
                else:
                    miss_count = 0

        time.sleep(interval)


# ── Entry point ────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        description="Lock KDE screen when Bluetooth device leaves range."
    )
    parser.add_argument("--mac", required=True, metavar="AA:BB:CC:DD:EE:FF")
    parser.add_argument("--daemon", action="store_true",
                        help="Run as background daemon")
    args = parser.parse_args()

    parts = args.mac.upper().split(":")
    if len(parts) != 6 or not all(
        len(p) == 2 and all(c in "0123456789ABCDEF" for c in p) for p in parts
    ):
        parser.error(f"Invalid MAC: {args.mac}")

    # Write initial config if missing
    if not os.path.exists(CONFIG_FILE):
        cfg = DEFAULT_CONFIG.copy()
        cfg["mac"] = args.mac.upper()
        os.makedirs(CONFIG_DIR, exist_ok=True)
        with open(CONFIG_FILE, "w") as f:
            json.dump(cfg, f, indent=2)

    monitor(mac=args.mac.upper(), run_as_daemon=args.daemon)


if __name__ == "__main__":
    main()
